// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id                    String    @id @default(uuid())
  email                 String?   @unique
  phoneNumber           String    @unique
  passwordHash          String
  fullName              String
  avatarUrl             String?
  bio                   String    @default("")
  isAvailable           Boolean   @default(true)
  availability          Json?
  passwordLastChangedAt DateTime?
  twoFactorAuthEnabled  Boolean   @default(false)

  // On-Demand Specifics
  role         UserRole   @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  rating       Float      @default(0.0)
  totalReviews Int        @default(0)
  isVerified   Boolean    @default(false)

  locations Location[] // Format: { lat: number, lng: number }

  // Metadata & Security
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  writtenReviews  Review[] @relation("WrittenReviews")
  receivedReviews Review[] @relation("ReceivedReviews")

  services      Service[]      @relation("ServiceProvider")
  bankAccounts  BankAccount[]
  notifications Notification[]
  jobs          Job[]
  jobsSent      Job[]          @relation("CustomerJobs")

  @@index([email, phoneNumber])
  @@index([role, status])
}

model Location {
  id        String @id @default(uuid())
  latitude  Float
  longitude Float
  address   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String
  image       String?
  gallery     String[]

  // Features stored as a list of strings
  features String[]

  // Relationships
  providerId String
  provider   User     @relation("ServiceProvider", fields: [providerId], references: [id], onDelete: Cascade)
  reviews    Review[]

  // Aggregates (Can be calculated, but often stored for performance)
  rating      Float @default(0.0)
  reviewCount Int   @default(0)

  // Availability / Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@index([category])
}

model BankAccount {
  id            String   @id @default(uuid())
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  isPrimary     Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bank {
  id                      String   @id @default(uuid())
  name                    String
  slug                    String   @unique
  code                    String   @unique
  longcode                String?
  gateway                 String?
  payWithBank             Boolean  @default(false) @map("pay_with_bank")
  supportsTransfer        Boolean  @default(true) @map("supports_transfer")
  availableForDirectDebit Boolean  @default(false) @map("available_for_direct_debit")
  active                  Boolean  @default(true)
  country                 String   @default("Nigeria")
  currency                String   @default("NGN")
  type                    String   @default("nuban")
  isDeleted               Boolean  @default(false) @map("is_deleted")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("banks") // Maps the model to a lowercase table name in the DB
}

// schema.prisma

enum NotificationType {
  PAYOUT
  JOB
  SYSTEM
  MESSAGE
  ALERT
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Review {
  id      String @id @default(cuid()) // Added default ID generator
  rating  Int
  comment String @db.Text

  // The person writing the review
  authorId String
  author   User   @relation("WrittenReviews", fields: [authorId], references: [id])

  // The person being reviewed (Provider)
  providerId String
  provider   User   @relation("ReceivedReviews", fields: [providerId], references: [id])

  // The specific service being reviewed
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

enum JobStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

model Job {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  urgency     Urgency  @default(MEDIUM)
  budget      Int?
  images      String[]

  status JobStatus @default(PENDING)

  customerId String
  customer   User   @relation("CustomerJobs", fields: [customerId], references: [id])

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([customerId])
  @@index([serviceId])
}
