// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id                    String    @id @default(uuid())
  email                 String?   @unique
  phoneNumber           String    @unique
  passwordHash          String
  fullName              String
  avatarUrl             String?
  bio                   String    @default("")
  isAvailable           Boolean   @default(true)
  availability          Json?
  passwordLastChangedAt DateTime?
  twoFactorAuthEnabled  Boolean   @default(false)

  // On-Demand Specifics
  role       UserRole   @default(CUSTOMER)
  status     UserStatus @default(ACTIVE)
  rating     Float      @default(0.0)
  isVerified Boolean    @default(false)

  // Location tracking (Prisma 7 handles JSON natively for GeoJSON)
  locations Location[] // Format: { lat: number, lng: number }

  // Metadata & Security
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reviews      Review[]      @relation("Reviewer")
  services     Service[]     @relation("ServiceProvider")
  bankAccounts BankAccount[]

  @@index([email, phoneNumber])
  @@index([role, status])
}

model Location {
  id        String @id @default(uuid())
  latitude  Float
  longitude Float
  address   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Service {
  id          String  @id @default(uuid())
  title       String
  description String  @db.Text
  category    String
  image       String?

  // Features stored as a list of strings
  features String[]

  // Relationships
  providerId String
  provider   User     @relation("ServiceProvider", fields: [providerId], references: [id], onDelete: Cascade)
  reviews    Review[]

  // Aggregates (Can be calculated, but often stored for performance)
  rating      Float @default(0.0)
  reviewCount Int   @default(0)

  // Availability / Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Review {
  id      String @id @default(uuid())
  rating  Int
  comment String @db.Text

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("Reviewer", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model BankAccount {
  id            String   @id @default(uuid())
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  isPrimary     Boolean
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bank {
  id                      Int      @id
  name                    String
  slug                    String   @unique
  code                    String   @unique
  longcode                String?
  gateway                 String?
  payWithBank             Boolean  @default(false) @map("pay_with_bank")
  supportsTransfer        Boolean  @default(true) @map("supports_transfer")
  availableForDirectDebit Boolean  @default(false) @map("available_for_direct_debit")
  active                  Boolean  @default(true)
  country                 String   @default("Nigeria")
  currency                String   @default("NGN")
  type                    String   @default("nuban")
  isDeleted               Boolean  @default(false) @map("is_deleted")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("banks") // Maps the model to a lowercase table name in the DB
}
